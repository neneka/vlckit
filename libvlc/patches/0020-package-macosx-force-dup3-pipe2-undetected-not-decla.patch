From 54e33620ac2f1c2b467b391149e9447f34b26a30 Mon Sep 17 00:00:00 2001
From: Branko Vucinec <hello@justfox.dev>
Date: Wed, 8 Jul 2026 10:36:58 +0200
Subject: [PATCH 20/20] package/macosx: force dup3()/pipe2() undetected (not
 declared in Apple SDK headers)

dup3() and pipe2() are not declared in the Apple SDK headers. On the iOS/tvOS/watchOS/
visionOS simulator SDKs the symbols are still linkable (exported by the simulator runtime),
so configure's link-only AC_CHECK_FUNCS test false-positives and the resulting call fails to
compile (error: call to undeclared function). Disable them in vlcSetSymbolEnvironment
alongside the other functions unavailable on the minimal Apple targets.

Signed-off-by: Branko Vucinec <hello@justfox.dev>
---
 extras/package/macosx/env.build.sh | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/extras/package/macosx/env.build.sh b/extras/package/macosx/env.build.sh
index 5591283e1f..a14cd09c04 100755
--- a/extras/package/macosx/env.build.sh
+++ b/extras/package/macosx/env.build.sh
@@ -118,6 +118,9 @@ vlcSetSymbolEnvironment() {
     #
     # ac_cv_prog_cc_c23: autoconf 2.73 adds -std=gnu23 to CC but not OBJC
     #                    breaking libtool's ObjC tag inference.
+    #
+    # ac_cv_func_dup3 / ac_cv_func_pipe2: undeclared in Apple SDK headers but
+    #   falsely link-detectable since iOS simulator SDK 26.4.
     "${cmd}" "$@" \
     \
     ac_cv_prog_cc_c23=no \
@@ -138,6 +141,9 @@ vlcSetSymbolEnvironment() {
     ac_cv_func_futimens=no \
     ac_cv_func_utimensat=no \
     \
+    ac_cv_func_dup3=no \
+    ac_cv_func_pipe2=no \
+    \
     ac_cv_func_thread_get_register_pointer_values=no \
     \
     ac_cv_func_aligned_alloc=no \
