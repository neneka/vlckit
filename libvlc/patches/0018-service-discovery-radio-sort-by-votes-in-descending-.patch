From: =?UTF-8?q?Felix=20Paul=20K=C3=BChne?= <fkuehne@videolan.org>
Date: Mon, 13 Jul 2026 13:49:14 +0200
Subject: [PATCH 18/20] service discovery/radio: sort by votes in descending
 order instead of random

---
 modules/services_discovery/radio.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/modules/services_discovery/radio.c b/modules/services_discovery/radio.c
index c8d59a5add..3edf11fad2 100644
--- a/modules/services_discovery/radio.c
+++ b/modules/services_discovery/radio.c
@@ -406,7 +406,7 @@ static int ReadDirectory(stream_t *p_access, input_item_node_t *p_node)
     }
 
     char *stations_endpoint;
-    if (asprintf(&stations_endpoint, "%scsv/stations/bycountrycodeexact/%s?hidebroken=true&order=random",
+    if (asprintf(&stations_endpoint, "%scsv/stations/bycountrycodeexact/%s?hidebroken=true&order=votes&reverse=true",
                  p_sys->base_url, p_access->psz_location) < 0)
     {
         return VLC_ENOMEM;
