From 2c5b9f14332da98d39ade70bb28905484b9ff851 Mon Sep 17 00:00:00 2001
From: Ayush Dey <deyayush6@gmail.com>
Date: Tue, 16 Sep 2025 12:04:39 +0530
Subject: [PATCH 15/20] input: add vlctest_ protocol

Add vlctest_ protocol as a file type. This will be required
in the next commit for using a dummy access module with the
libvlc_downloader.
---
 src/input/item.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/src/input/item.c b/src/input/item.c
index f5c4dfde4c..df13c322fe 100644
--- a/src/input/item.c
+++ b/src/input/item.c
@@ -1218,6 +1218,7 @@ static enum input_item_type_e GuessType( const input_item_t *p_item, bool *p_net
         { "v4l",    ITEM_TYPE_CARD, false },
         { "vcd",    ITEM_TYPE_DISC, false },
         { "vdr",    ITEM_TYPE_STREAM, true },
+        { "vlctest_",ITEM_TYPE_FILE, false },
         { "wasapi", ITEM_TYPE_CARD, false },
         { "window", ITEM_TYPE_CARD, false },
     };
